# Frontend (Vite — baked at build time)
VITE_ORY_SDK_URL=https://auth.headout.com

# Ory session cookie name — must match across Vite (dev cookie) and API (whoami).
# Prod slug angry-hertz-… → ory_session_angryhertzf78ol5nls8
# Confirm with Guardian/platform for the project Storefront uses.
ORY_SESSION_COOKIE_NAME=ory_session_angryhertzf78ol5nls8

# Dev-only: opaque cookie VALUE (not name=value). Hit GET /__dev-auth-cookie
# after setting this. Never commit a real token.
# ORY_SESSION_TOKEN=

# Local Vite → API proxy (api-server default listen address)
# API_PROXY_TARGET=http://127.0.0.1:8080

# API server — Guardian whoami (defaults to https://guardian.headout.com)
# GUARDIAN_BASE_URL=https://guardian.headout.com

# Temporary: skip Guardian SSO until storefront.headout.com DNS works.
# AUTH_BYPASS=true

# After Guardian PR merges + deploys (STOREFRONT in OryApplication enum):
# GUARDIAN_APPLICATION_NAME=STOREFRONT

# Anthropic (public API). Base URL only if routing through a gateway.
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=
# CLAUDE_MODEL=claude-sonnet-4-6

# Delphi MCP — Headout org knowledge beyond the catalogue (repos, Notion/Coda/GDocs).
# Create a key via Slack: /create-delphi-api-key
# DELPHI_API_KEY=
# DELPHI_MCP_URL=https://delphi.headout.com/tools/mcp
# DELPHI_TIMEOUT_MS=90000

# App — local split-process: Vite storefront on PORT, API on 8080 (see API_PROXY_TARGET).
# Docker/Railway: single process uses PORT=8080 for Express (serves SPA + API).
PORT=5173
BASE_PATH=/
DATABASE_URL=
ALLOWED_EMAIL_DOMAIN=@headout.com
